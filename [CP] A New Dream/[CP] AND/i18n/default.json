//Display Name
"FC.Popper": "Pop",
//Gift Related dialogue
"Popper.gift.love": "Wow!#$b#How’d you know I love this thing!#$b#I will keep it forever!",
"Popper.gift.like": "This is for me?#$b#Very nice, I’ll keep this safe.",
"Popper.gift.dislike": "Such a mean human!",
"Popper.gift.hate": "No keep it away!#$b#Stop bullying me!",
"Popper.gift.neutral": "You are sure?#$b#I keep this?",
"Popper.AcceptGift_Fellowclown.TW_ArkaCoin": "Shiny!$1#$b#But wait....No bad taste, bad sickness...$2",
"Popper.accept_ArkaCoin": "Oh!$1#$b#Oh, shiny!$1#$b#It's mine now!$6",
"Popper.AcceptGift_91": "Banana! Banana! I love bananas!$1",
"Popper.AcceptGift_Fellowclown.AND_Button": "For me?!$1#$b#Mine! Yes, mine!$1",
"Popper.reject_116": "No...$2#$b#It's…It's dead, isn't it?$2",
"Popper.reject_809": "No!$2#$b#Too load for Pop.$2",
"reject_Fellowclown.TW_DragaWhiskey": "Ew!$5#$b#Yuck juice!$5",
//Special Dialogue
"DumpsterDiveComment.Popper": "Hey!$3#$b#That's mine, get your own trash, buddy!$3",
"RejectBouquet_NotDatable.Popper": "Haha, never!$1#$b#Silly human!$1",
"HitBySlingshot.Popper": "Is hit! Is hit!$5#$b#Someone save Pop!$5",
"intro.Popper.Popper": "Oh!$5#$b#...#$b#Huh, you are safe?$1#$b#Yes, safe!",
"Resort_Entering.Popper": "Look! Sand!",
"Resort_Leaving.Popper": "So sleepy, wanna sleep.",
"Resort_Shore.Popper": "Sand is so good!$1#$b#Nice and crunchy.$6",
"Resort_Umbrella.Popper": "Sun was too hot, don't like getting too hot.$2#$b#It makes me feel sick!$5",
"Resort_Wander.Popper": "I saw a bug, it was very big.#$b#Looked tasty.$6",
"Resort_Bar.Popper": "Shh, don't tell am here.#$b#I am sneaking.$6",
"Resort.Popper": "Nice place, but animals here are very scary...$5",
//Everyday Dialgoue
"mon.Popper.spring": "Hey, I don't belong in this town.$2#$b#But I'll make it perfect.$6",
"tue.Popper.spring": "@!@!#$b#Bald man has best trash.$1#$b#Very strange, why throw away good things?$2",
"wed.Popper.spring": "Whenever I get lonely, I mess with kitty.#$b#She'll never catch me!$6",
"thu.Popper.spring": "Have you checked your hands?#$b#I did and is strange, why don't I I have five claws like humans?$2",
"fri.Popper.spring": "Hm? What?#$b#You bug me too much...$2#$b#Wait, you aren't dangerous? Right?$5#$e#Stay away! I will bite, bite, bite!$3",
"sat.Popper.spring": "%He's pretending he doesn't see you, but from the way he keeps side-eyeing you, it's obvious he does see you. He won’t admit it, though. He's being evil today!",
"sun.Popper.spring": "You!#$b#Take this and run! Don't let anyone take it from you!$5[168]",
"mon.Popper.summer": "Do humans really eat crabs?$2#$b#Yuck! Nasty!$5",
"tue.Popper.summer": "Hey, @!#$b#Why did the chicken cross the road?$1#$b#To...$1#$b#To uh...can't remember joke...$2",
"wed.Popper.summer": "Are stars jealous of sun?$2#$b#Do they feel, do they want to be bigger too?$2",
"thu.Popper.summer": "I've never seen any human tails.#$b#That's so sad.$2#$b#I love my tail so much.$2",
